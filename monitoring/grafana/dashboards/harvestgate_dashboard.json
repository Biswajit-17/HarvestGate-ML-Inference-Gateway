        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 8,
      "title": "Drift Detection - Feature PSI Score",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
